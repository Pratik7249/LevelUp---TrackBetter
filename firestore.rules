rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, create, update: if owns(userId);
      allow delete: if false;

      // Covers settings, accounts, categories, transactions, holdings,
      // portfolioSnapshots, habits, habitLogs, messLogs and reports.
      match /{document=**} {
        allow read, write: if owns(userId);
      }
    }
  }
}
